module baud_generator (
    input clk , 
    input reset,
    output reg tx_tick
);

parameter MAX_COUNT = 5208;

reg [15:0] counter;

always @(posedge clk) begin
    if (reset) begin
        tx_tick <= 1'b0;
        counter <= 16'd0;   
    end
    else begin
        if (counter == MAX_COUNT - 1) begin
            tx_tick <= 1'b1;
            counter <= 16'd0; 
        end
        else begin
            counter <= counter + 1'b1;
            tx_tick <= 1'b0;
        end
    end   
end
endmodule
